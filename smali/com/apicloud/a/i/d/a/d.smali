.class public Lcom/apicloud/a/i/d/a/d;
.super Landroid/graphics/RectF;


# direct methods
.method public constructor <init>()V
    .locals 0

    invoke-direct {p0}, Landroid/graphics/RectF;-><init>()V

    return-void
.end method


# virtual methods
.method public a(FFFF)V
    .locals 0

    add-float/2addr p3, p1

    add-float/2addr p4, p2

    invoke-virtual {p0, p1, p2, p3, p4}, Lcom/apicloud/a/i/d/a/d;->set(FFFF)V

    return-void
.end method
